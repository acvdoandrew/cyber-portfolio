---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andrew Acevedo Mirena // Systems Programmer',
  description = 'Systems programmer in Boston building public proof-of-work across distributed systems, AI infrastructure, security research, and decision-support tools.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Andrew Acevedo Mirena',
  url: 'https://www.aceandrew.com/',
  sameAs: [
    'https://github.com/acvdoandrew',
    'https://x.com/etobyte',
  ],
  homeLocation: {
    '@type': 'Place',
    name: 'Boston / Cambridge, Massachusetts',
  },
  knowsAbout: [
    'Rust',
    'Distributed systems',
    'AI infrastructure',
    'Security research',
    'C++',
    'TypeScript',
  ],
};
---
<!doctype html>
<html lang="en" data-crt="on" data-entity="on" data-renderer="canvas" data-fx-quality="high">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="author" content="Andrew Acevedo Mirena" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/VT323-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Andrew // Signal Console" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@etobyte" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script is:inline>
      (() => {
        try {
          const crt = localStorage.getItem('andrew-crt');
          const entity = localStorage.getItem('andrew-entity');
          document.documentElement.dataset.crt = crt === 'off' ? 'off' : 'on';
          document.documentElement.dataset.entity = entity === 'off' ? 'off' : 'on';
        } catch {
          document.documentElement.dataset.crt = 'on';
          document.documentElement.dataset.entity = 'on';
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <canvas id="signal-field" class="signal-field" aria-hidden="true"></canvas>
    <canvas id="signal-compositor" class="signal-compositor" aria-hidden="true"></canvas>
    <canvas id="gpu-stage" class="gpu-stage" aria-hidden="true"></canvas>
    <canvas id="braille-entity" class="braille-entity" aria-hidden="true"></canvas>
    <div class="ambient-light" aria-hidden="true"></div>
    <div class="transmission-fragments" aria-hidden="true">
      <span class="fragment fragment--one"></span>
      <span class="fragment fragment--two"></span>
      <span class="fragment fragment--three"></span>
      <span class="fragment fragment--four"></span>
      <span class="fragment fragment--five"></span>
    </div>
    <div class="crt-layer" aria-hidden="true"></div>
    <div class="noise-layer" aria-hidden="true"></div>
    <div class="scroll-progress" aria-hidden="true"><span id="scroll-progress-bar"></span></div>
    <slot />
    <script is:inline src="/scripts/interface.js"></script>
    <script is:inline src="/scripts/compositor.js"></script>
    <script is:inline src="/scripts/entity.js"></script>
    <script>
      import '../scripts/gpu-runtime';
    </script>
  </body>
</html>
