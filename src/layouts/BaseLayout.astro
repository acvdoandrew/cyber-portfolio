---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ANDREW_TERMINAL // vOS',
  description = 'I build weird systems in Rust and Python: distributed compute, simulations, security tooling, and AI infra. You can inspect the work yourself.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Andrew',
  url: 'https://www.aceandrew.com/',
  sameAs: [
    'https://github.com/acvdoandrew',
    'https://x.com/etobyte',
  ],
  homeLocation: {
    '@type': 'Place',
    name: 'Boston / Cambridge, Massachusetts',
  },
  knowsAbout: [
    'Rust',
    'Distributed systems',
    'AI infrastructure',
    'Security research',
    'C++',
    'TypeScript',
  ],
};
---
<!doctype html>
<html lang="en" data-theme="system" data-theme-resolved="dark" data-crt="on" data-entity="on" data-renderer="canvas" data-fx-quality="high" data-fx-reason="boot">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content={description} />
    <meta name="author" content="Andrew" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/Doto-Black.ttf" as="font" type="font/ttf" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ANDREW_TERMINAL // vOS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@etobyte" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script is:inline>
      (() => {
        try {
          const crt = localStorage.getItem('andrew-crt');
          const entity = localStorage.getItem('andrew-entity');
          const savedTheme = localStorage.getItem('andrew-theme');
          const theme = ['system', 'light', 'dark'].includes(savedTheme || '') ? savedTheme : 'system';
          const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const resolvedTheme = theme === 'system' ? (systemDark ? 'dark' : 'light') : theme;
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.themeResolved = resolvedTheme;
          document.querySelector('meta[name="theme-color"]')?.setAttribute('content', resolvedTheme === 'light' ? '#f1eee8' : '#050505');
          document.documentElement.dataset.crt = crt === 'off' ? 'off' : 'on';
          document.documentElement.dataset.entity = entity === 'off' ? 'off' : 'on';
        } catch {
          document.documentElement.dataset.theme = 'system';
          document.documentElement.dataset.themeResolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.crt = 'on';
          document.documentElement.dataset.entity = 'on';
        }
        document.documentElement.classList.add('session-pending');
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <canvas id="signal-field" class="signal-field" aria-hidden="true"></canvas>
    <canvas id="signal-compositor" class="signal-compositor" aria-hidden="true"></canvas>
    <div id="entity-runtime-root" class="entity-runtime-root" aria-hidden="true" data-entity-ignore>
      <canvas id="gpu-stage" class="gpu-stage" aria-hidden="true"></canvas>
      <canvas id="braille-entity" class="braille-entity" aria-hidden="true"></canvas>
      <output id="entity-thought" class="entity-thought" aria-hidden="true"></output>
    </div>
    <div class="ambient-light" aria-hidden="true"></div>
    <canvas id="signal-rain" class="signal-rain" aria-hidden="true"></canvas>
    <div class="crt-layer" aria-hidden="true"></div>
    <div class="noise-layer" aria-hidden="true"></div>
    <div class="scroll-progress" aria-hidden="true"><span id="scroll-progress-bar"></span></div>
    <slot />
    <script is:inline src="/scripts/compositor.js"></script>
    <script is:inline src="/scripts/interface.js"></script>
    <script>
      import '../scripts/gpu-runtime';
      import '../scripts/entity/canvas-renderer';
    </script>
  </body>
</html>
