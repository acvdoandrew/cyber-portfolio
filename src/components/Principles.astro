---
import SectionSpecimen from './SectionSpecimen.astro';

const principles = [
  {
    code: 'P.01',
    title: 'MAKE IT STRANGE.',
    accent: 'KEEP IT TRUE.',
    note: 'Make the interface distinct. Keep every claim exact.',
  },
  {
    code: 'P.02',
    title: 'BENCHMARK BEFORE',
    accent: 'BRAGGING.',
    note: 'Measure first. Then describe the result.',
  },
  {
    code: 'P.03',
    title: 'FOLLOW THE',
    accent: 'FAILURE.',
    note: 'Failures expose the real system.',
  },
  {
    code: 'P.04',
    title: 'LEAVE THE',
    accent: 'SOURCE OPEN.',
    note: 'Useful work should be inspectable.',
  },
];
---
<section class="principles section-shell" id="log" data-section="log">
  <header class="section-heading reveal" data-reveal data-entity-obstacle="principles-heading">
    <div>
      <span class="section-index">03 / OPERATING_PRINCIPLES</span>
      <h2>How I work.</h2>
    </div>
    <SectionSpecimen kind="orbit" entityHost="section:log" approach="either" />
    <p>
      The rules I use when systems get complicated.
    </p>
  </header>

  <div class="principle-grid" data-entity-obstacle="principle-cards">
    {principles.map((principle, index) => (
      <article class="principle-card reveal" data-reveal style={`--delay:${index * 55}ms`}>
        <span class="principle-code">{principle.code}</span>
        <h3>{principle.title}<br /><em>{principle.accent}</em></h3>
        <p>{principle.note}</p>
        <span class="principle-bracket" aria-hidden="true">[ MARGIN_NOTE ]</span>
      </article>
    ))}
  </div>

  <div class="ops-log reveal" data-reveal data-entity-obstacle="ops-log">
    <div class="ops-log-head">
      <span>// OPS_LOG</span>
      <span>READ_ONLY</span>
    </div>
    <ol>
      <li>
        <time>NOW</time>
        <span class="log-pip log-pip--green"></span>
        <div><strong>ARES frontier seed committed</strong><p><code>ares-core</code>, <code>ares-settlement</code>, and <code>ares-cli</code> initialize private frontier state with deterministic CLI output and eight passing tests.</p></div>
      </li>
      <li>
        <time>NEXT</time>
        <span class="log-pip log-pip--pink"></span>
        <div><strong>First deterministic settlement turn</strong><p>One typed capacity allocation. One complete turn. No dashboard-shaped escape route.</p></div>
      </li>
      <li>
        <time>ORDER</time>
        <span class="log-pip log-pip--amber"></span>
        <div><strong>World → agents → replay → dashboard</strong><p>Hosted models remain locked outside until the world can prove what happened.</p></div>
      </li>
    </ol>
  </div>
</section>
