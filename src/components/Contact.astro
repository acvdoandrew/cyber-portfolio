---
import SectionSpecimen from './SectionSpecimen.astro';
---
<section class="contact section-shell" id="contact" data-section="contact">
  <div class="contact-panel reveal" data-reveal>
    <div class="contact-copy">
      <div class="contact-heading-row">
        <div>
          <span class="section-index">04 / CONTACT</span>
          <h2>Email me.</h2>
        </div>
        <SectionSpecimen kind="relay" />
      </div>
      <p>
        Working on infrastructure, security, or an odd technical problem?
        Tell me what you are building and where it is stuck.
      </p>
      <div class="availability-line"><i></i><span>RECEIVING // REAL_PROBLEMS / PLAIN_TEXT</span></div>
    </div>

    <div class="terminal-contact" aria-label="Contact methods">
      <div class="terminal-titlebar">
        <span>operator@uplink:~</span>
        <div aria-hidden="true"><i></i><i></i><i></i></div>
      </div>
      <div class="terminal-body">
        <p class="terminal-line"><span class="prompt"><span data-session-user>guest</span>@signal:~$</span> ./connect --available</p>
        <p class="terminal-output">Scanning public channels... <strong>3 FOUND</strong></p>

        <a class="contact-command" href="mailto:acvdoandrew@gmail.com">
          <span><small>01 // EMAIL</small><strong>acvdoandrew@gmail.com</strong></span>
          <span aria-hidden="true">↗</span>
        </a>
        <a class="contact-command" href="https://github.com/acvdoandrew" target="_blank" rel="noopener noreferrer">
          <span><small>02 // SOURCE_NODE</small><strong>github.com/acvdoandrew</strong></span>
          <span aria-hidden="true">↗</span>
        </a>
        <a class="contact-command" href="https://x.com/etobyte" target="_blank" rel="noopener noreferrer">
          <span><small>03 // SHORTWAVE</small><strong>x.com/etobyte</strong></span>
          <span aria-hidden="true">↗</span>
        </a>

        <div class="terminal-actions">
          <button class="copy-button" type="button" data-copy-email="acvdoandrew@gmail.com">
            <span data-copy-label>COPY_EMAIL</span><span aria-hidden="true">[ ]</span>
          </button>
          <button class="copy-button" type="button" data-command-open>
            OPEN_COMMAND_DECK<span aria-hidden="true" data-command-shortcut>CTRL K</span>
          </button>
        </div>
        <p class="terminal-cursor" aria-hidden="true"><span class="prompt"><span data-session-user>guest</span>@signal:~$</span> <i></i></p>
        <p class="sr-only" id="copy-status" aria-live="polite"></p>
      </div>
    </div>
  </div>
</section>
