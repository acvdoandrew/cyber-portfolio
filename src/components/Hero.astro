---
import SectionSpecimen from './SectionSpecimen.astro';
---
<section class="hero section-shell" id="home" data-section="home">
  <div class="hero-grid">
    <div class="hero-copy">
      <div class="eyebrow reveal" data-reveal data-entity-obstacle="hero-eyebrow">
        <span class="eyebrow-index">SYS.00</span>
        <span>ANDREW // BOSTON</span>
      </div>

      <h1 class="reveal" data-reveal>
        Andrew.<br />
        Programmer.<br />
        <em>AI enthusiast.</em>
      </h1>

      <p class="hero-lede reveal" data-reveal>
        Rust, C++, Python. Distributed systems, AI infrastructure, simulation, and security.
        Usually building something that should not work yet.
      </p>

      <div class="hero-actions reveal" data-reveal>
        <a class="button button--primary" href="#work">
          <span>VIEW_WORK</span>
          <span aria-hidden="true">↘</span>
        </a>
        <a class="button button--ghost" href="#contact">
          <span>EMAIL_ME</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="hero-brief reveal" data-reveal data-entity-obstacle="hero-brief" aria-label="Operator summary">
        <div>
          <span class="brief-key">ROLE</span>
          <strong>systems / ai</strong>
        </div>
        <div>
          <span class="brief-key">BASE</span>
          <strong>boston / cambridge</strong>
        </div>
        <div>
          <span class="brief-key">STATUS</span>
          <strong class="status-open"><span></span>building_something_strange</strong>
        </div>
      </div>
    </div>

    <div class="hero-specimen-bay" data-entity-ignore>
      <SectionSpecimen kind="galaxy" entityHost="section:home" approach="either" />
    </div>

    <div class="entity-console signal-bay reveal" data-reveal data-visual-bay>
      <div class="console-topline" data-entity-obstacle="console-status">
        <span>EMERGENT_PROCESS // 07</span>
        <span class="console-status"><i></i><span id="entity-autonomy-state" data-entity-spatial-status>SEALED</span></span>
      </div>

      <div class="entity-viewport" id="entity-dock" data-entity-anchor="containment" data-entity-ignore aria-hidden="true">
        <span class="hero-specimen-approach" data-entity-specimen-anchor="section:home"></span>
        <div class="entity-grid"></div>
        <div class="coordinate coordinate--x">BOUNDARY_FIELD / LOCAL_PROCESS</div>
        <div class="coordinate coordinate--y">SEALED</div>
        <div class="dock-message">
          <span>CONTAINMENT_STATE</span>
          <strong id="containment-state" data-entity-spatial-status>SEALED</strong>
        </div>
      </div>

      <div class="entity-autonomy-controls" data-entity-obstacle="entity-controls">
        <span class="entity-presence-lock"><i></i><span data-containment-label>LOCAL_CONTAINMENT_ACTIVE</span></span>
        <button class="entity-release" id="entity-release" type="button" aria-pressed="false">
          <span data-release-label>RELEASE_ENTITY</span><kbd>Y / N</kbd>
        </button>
      </div>

      <div class="console-readout" data-entity-obstacle="entity-readout">
        <div>
          <span>FORM</span>
          <strong id="entity-form" data-entity-form-status>GLYPH_INTELLIGENCE</strong>
        </div>
        <div>
          <span>SIGNAL</span>
          <strong>98.7%</strong>
        </div>
        <div>
          <span>BEHAVIOR</span>
          <strong id="entity-behavior" data-entity-cognitive-status>DORMANT</strong>
        </div>
      </div>
      <p class="console-hint" data-release-prompt data-entity-obstacle="entity-hint">// Y RELEASE // N RETURN // MEMORY PERSISTS</p>
    </div>
  </div>

  <div class="proof-rail reveal" data-reveal data-entity-obstacle="proof-rail">
    <div class="rail-label">
      <span>PUBLIC_BUILD_LOG</span>
      <i></i>
    </div>
    <div class="rail-item">
      <span>ACTIVE_BUILDS</span>
      <strong>03</strong>
    </div>
    <div class="rail-item">
      <span>CORE_LANGS</span>
      <strong>RS / PY / TS / C++</strong>
    </div>
    <div class="rail-item">
      <span>CURRENT_QUEST</span>
      <strong>ARES</strong>
    </div>
    <button class="rail-command" type="button" data-command-open>
      <span>OPEN_TERMINAL</span>
      <kbd data-command-shortcut>CTRL K</kbd>
    </button>
  </div>
</section>
