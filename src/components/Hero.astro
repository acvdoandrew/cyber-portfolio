      </div>

      <div class="entity-viewport" id="entity-dock" aria-hidden="true">
        <span class="corner corner--tl"></span>
        <span class="corner corner--tr"></span>
        <span class="corner corner--bl"></span>
        <span class="corner corner--br"></span>
        <div class="target-reticle"><span></span></div>
        <div class="entity-grid"></div>
        <div class="coordinate coordinate--x">X.042 / FIELD_REACTIVE</div>
        <div class="coordinate coordinate--y">Y.117</div>
        <div class="dock-message">
          <span>OBSERVER_FIELD</span>
