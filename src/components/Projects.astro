---
import SectionSpecimen from './SectionSpecimen.astro';
---
<section class="projects section-shell" id="work" data-section="work">
  <header class="section-heading reveal" data-reveal>
    <div>
      <span class="section-index">01 / WORK</span>
      <h2>Built, broken, still running.</h2>
    </div>
    <SectionSpecimen kind="black-hole" />
    <p>
      The source is there. So are the rough edges.
    </p>
  </header>

  <article class="quest-banner reveal" data-reveal>
    <div class="quest-signal" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="quest-meta">
      <span class="case-index">CURRENT_QUEST // OBJ_00</span>
      <div class="status-chip status-chip--pink"><i></i>DESIGNING</div>
    </div>
    <div class="quest-copy">
      <div>
        <h3>ARES</h3>
        <p class="quest-name">Airspace Reasoning &amp; Evaluation Sandbox</p>
      </div>
      <p>
        A deterministic sandbox for simulating contested airspace and evaluating AI agents.
        Rust simulation core, Python evals, and a TypeScript/MapLibre interface.
      </p>
    </div>
    <div class="quest-stack" aria-label="ARES technology stack">
      <span>RUST</span><span>PYTHON</span><span>TYPESCRIPT</span><span>FASTAPI</span><span>MAPLIBRE</span>
    </div>
    <div class="quest-state">REPOSITORY // STAGING</div>
  </article>

  <article class="casefile casefile--flagship signal-bay reveal" data-reveal data-tilt data-visual-bay data-case="01">
    <div class="casefile-visual network-visual" aria-hidden="true">
      <div class="visual-toolbar">
        <span>EDGE_MESH // LIVE_MODEL</span>
        <span>HEARTBEAT: 01.0s</span>
      </div>
      <svg viewBox="0 0 720 330" role="presentation">
        <defs>
          <linearGradient id="mesh-line" x1="0" x2="1">
            <stop offset="0" stop-color="#d6d1ce" stop-opacity=".15" />
            <stop offset=".52" stop-color="#a9bec0" stop-opacity=".9" />
            <stop offset="1" stop-color="#a96d86" stop-opacity=".2" />
          </linearGradient>
          <filter id="soft-glow"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <g class="mesh-grid">
          <path d="M0 55H720M0 110H720M0 165H720M0 220H720M0 275H720" />
          <path d="M90 0V330M180 0V330M270 0V330M360 0V330M450 0V330M540 0V330M630 0V330" />
        </g>
        <g class="mesh-routes">
          <path d="M120 92 C250 92 240 165 360 165" />
          <path d="M120 245 C245 245 252 165 360 165" />
          <path d="M360 165 C470 165 482 78 605 78" />
          <path d="M360 165 C468 165 500 252 605 252" />
        </g>
        <g class="mesh-packets" filter="url(#soft-glow)">
          <circle r="4"><animateMotion dur="2.6s" repeatCount="indefinite" path="M120 92 C250 92 240 165 360 165" /></circle>
          <circle r="4"><animateMotion dur="3.1s" repeatCount="indefinite" path="M120 245 C245 245 252 165 360 165" /></circle>
          <circle r="4"><animateMotion dur="2.2s" repeatCount="indefinite" path="M360 165 C470 165 482 78 605 78" /></circle>
          <circle r="4"><animateMotion dur="2.9s" repeatCount="indefinite" path="M360 165 C468 165 500 252 605 252" /></circle>
        </g>
        <g class="mesh-node mesh-node--worker" transform="translate(70 56)">
          <rect width="100" height="72" />
          <text x="12" y="24">NODE_17</text><text x="12" y="47">GPU / SIM</text>
          <circle cx="83" cy="18" r="4" />
        </g>
        <g class="mesh-node mesh-node--worker" transform="translate(70 209)">
          <rect width="100" height="72" />
          <text x="12" y="24">NODE_42</text><text x="12" y="47">GPU / NVML</text>
          <circle cx="83" cy="18" r="4" />
        </g>
        <g class="mesh-node mesh-node--core" transform="translate(296 125)">
          <rect width="128" height="80" />
          <text x="16" y="28">ORCHESTRATOR</text><text x="16" y="54">gRPC : 50051</text>
          <circle cx="108" cy="20" r="5" />
        </g>
        <g class="mesh-node" transform="translate(555 42)">
          <rect width="100" height="72" />
          <text x="12" y="24">JOB_QUEUE</text><text x="12" y="47">LEASE / TTL</text>
        </g>
        <g class="mesh-node" transform="translate(555 216)">
          <rect width="100" height="72" />
          <text x="12" y="24">TELEMETRY</text><text x="12" y="47">STREAM / TUI</text>
        </g>
      </svg>
      <div class="visual-statusline"><span>4 CHANNELS ACTIVE</span><span>FAULT_TOLERANCE // ARMED</span></div>
    </div>

    <div class="casefile-copy">
      <div class="casefile-topline">
        <span class="case-index">DEPLOYMENT_01 // DISTRIBUTED_COMPUTE</span>
        <span class="status-chip status-chip--green"><i></i>SHIPPED_MVP</span>
      </div>
      <h3>Rust Edge Compute Node</h3>
      <p class="casefile-summary">
        A fault-tolerant control plane for distributed compute. Workers stream telemetry
        over gRPC while the orchestrator manages leases, priorities, and recovery.
      </p>
      <div class="build-notes">
        <span>BUILD_NOTES</span>
        <ul>
          <li>Async actor model with Tokio + Tonic</li>
          <li>Runtime-selectable telemetry HAL</li>
          <li>Jittered reconnect and stale-node eviction</li>
          <li>CI gates: fmt, clippy, tests, smoke run</li>
        </ul>
      </div>
      <div class="casefile-footer">
        <div class="stack-list"><span>RUST</span><span>TOKIO</span><span>TONIC</span><span>gRPC</span><span>RATATUI</span></div>
        <a class="text-link" href="https://github.com/acvdoandrew/rust-edge-compute" target="_blank" rel="noopener noreferrer">
          VIEW_SOURCE <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </article>

  <div class="casefile-grid">
    <article class="casefile casefile--compact signal-bay reveal" data-reveal data-tilt data-visual-bay data-case="02">
      <div class="casefile-visual particle-visual" aria-hidden="true">
        <div class="visual-toolbar"><span>PHYSICS_LOOP // FRAME_N</span><span>HASH: 12×08</span></div>
        <div class="particle-stage">
          <div class="hash-grid"></div>
          <i style="--x: 12%; --y: 25%; --dx: 48px; --dy: 36px"></i>
          <i style="--x: 27%; --y: 66%; --dx: -22px; --dy: -41px"></i>
          <i style="--x: 43%; --y: 39%; --dx: 34px; --dy: -19px"></i>
          <i style="--x: 61%; --y: 72%; --dx: -42px; --dy: -31px"></i>
          <i style="--x: 78%; --y: 31%; --dx: 18px; --dy: 42px"></i>
          <i style="--x: 88%; --y: 62%; --dx: -36px; --dy: 18px"></i>
          <span class="vector vector--one"></span><span class="vector vector--two"></span>
        </div>
        <div class="visual-statusline"><span>VERLET_INTEGRATION</span><span>BROAD_PHASE // ON</span></div>
      </div>
      <div class="casefile-copy">
        <div class="casefile-topline">
          <span class="case-index">DEPLOYMENT_02 // SIMULATION</span>
          <span class="status-chip status-chip--amber"><i></i>NEEDS_BENCHMARKS</span>
        </div>
        <h3>High-Performance Physics Engine</h3>
        <p class="casefile-summary">
          A C++17 particle engine for studying simulation loops, memory layout,
          and broad-phase collision performance.
        </p>
        <div class="milestone"><span>NEXT_MILESTONE</span><strong>benchmark collision broad-phase</strong></div>
        <div class="casefile-footer">
          <div class="stack-list"><span>C++17</span><span>CMAKE</span><span>SFML</span></div>
          <a class="text-link" href="https://github.com/acvdoandrew/high-performance-physics-engine" target="_blank" rel="noopener noreferrer">VIEW_SOURCE <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </article>

    <article class="casefile casefile--compact casefile--wip signal-bay reveal" data-reveal data-tilt data-visual-bay data-case="03">
      <div class="casefile-visual token-visual" aria-hidden="true">
        <div class="visual-toolbar"><span>INFERENCE_PROXY // TRACE</span><span>TTFT: TEST</span></div>
        <div class="token-stage">
          <div class="model-node"><span>DRAFT</span><strong>1B</strong></div>
          <div class="token-stream token-stream--draft"><i></i><i></i><i></i><i></i><i></i></div>
          <div class="model-node model-node--verify"><span>ORACLE</span><strong>70B</strong></div>
          <div class="token-stream token-stream--verify"><i></i><i></i><i></i><i></i></div>
          <div class="stream-output"><span>SSE</span><b></b><b></b><b></b></div>
        </div>
        <div class="visual-statusline"><span>SPECULATIVE_BATCH: 05</span><span>MOCK_BACKEND // FIRST</span></div>
      </div>
      <div class="casefile-copy">
        <div class="casefile-topline">
          <span class="case-index">DEPLOYMENT_03 // AI_INFRA</span>
          <span class="status-chip status-chip--pink"><i></i>COMPILING</span>
        </div>
        <h3>Speculative Inference Proxy</h3>
        <p class="casefile-summary">
          A Rust/Python gateway for speculative decoding, TTFT benchmarking, and
          vLLM-compatible serving. Mock backends first; real models after the metrics hold up.
        </p>
        <div class="milestone"><span>BUILD_ORDER</span><strong>mock draft/oracle → benchmark → real models</strong></div>
        <div class="casefile-footer">
          <div class="stack-list"><span>RUST</span><span>PYTHON</span><span>AXUM</span><span>vLLM</span></div>
          <a class="text-link" href="https://github.com/acvdoandrew/speculative-inference-proxy" target="_blank" rel="noopener noreferrer">VIEW_SOURCE <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </article>
  </div>
</section>
