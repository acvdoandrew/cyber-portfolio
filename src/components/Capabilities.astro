---
const modules = [
  {
    id: '01',
    title: 'SYSTEMS_PROGRAMMING',
    state: 'SHIPPING',
    tone: 'green',
    verb: 'Control planes, hot loops, and bugs that become educational around 2 a.m.',
    skills: ['Rust', 'C++', 'Linux', 'Bash', 'Tokio'],
  },
  {
    id: '02',
    title: 'AI_INFRA',
    state: 'INSTALLING',
    tone: 'pink',
    verb: 'Serving, evals, and measuring claims before adding the word revolutionary.',
    skills: ['Python', 'PyTorch', 'vLLM', 'FastAPI', 'Eval Harnesses'],
  },
  {
    id: '03',
    title: 'DISTRIBUTED_INFRA',
    state: 'FIELD_TESTED',
    tone: 'cyan',
    verb: 'Workers fail. Networks lie. The system still has to do something sensible.',
    skills: ['Docker', 'gRPC', 'Tonic', 'GitHub Actions'],
  },
  {
    id: '04',
    title: 'SECURITY_LABS',
    state: 'ACTIVE_LAB',
    tone: 'amber',
    verb: 'Assume the input is hostile. Occasionally, the input is me.',
    skills: ['Hack The Box', 'Web Security', 'Prompt Injection', 'Threat Modeling'],
  },
  {
    id: '05',
    title: 'PRODUCT_SURFACE',
    state: 'BUILDING',
    tone: 'violet',
    verb: 'Complicated systems deserve interfaces that do not require a webinar.',
    skills: ['TypeScript', 'React', 'MapLibre', 'Dashboards'],
  },
];
---
<section class="capabilities section-shell" id="stack" data-section="stack">
  <header class="section-heading reveal" data-reveal>
    <div>
      <span class="section-index">02 / SYSTEM_MAP</span>
      <h2>Tools I actually use.</h2>
    </div>
    <p>
      No percentage bars. No self-awarded expert badges. If it appears here, it has
      survived contact with a debugger.
    </p>
  </header>

  <div class="system-map reveal" data-reveal>
    <div class="system-bus" aria-hidden="true">
      <span>INPUT</span><i></i><strong>ANDREW_KERNEL</strong><i></i><span>OUTPUT</span>
    </div>
    <div class="module-list">
      {modules.map((module) => (
        <article class="module-row">
          <div class="module-number">MOD_{module.id}</div>
          <div class="module-name">
            <h3>{module.title}</h3>
            <p>{module.verb}</p>
          </div>
          <div class="module-skills">
            {module.skills.map((skill) => <span>{skill}</span>)}
          </div>
          <div class={`module-state module-state--${module.tone}`}><i></i>{module.state}</div>
        </article>
      ))}
    </div>
    <div class="system-map-footer">
      <span>PACKETS_ACCEPTED: CURIOUS_PROBLEMS</span>
      <span>OUTPUT_MODE: BUILD / BENCHMARK / BREAK / EXPLAIN</span>
    </div>
  </div>
</section>
