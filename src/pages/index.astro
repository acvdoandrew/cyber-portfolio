---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Capabilities from '../components/Capabilities.astro';
import Principles from '../components/Principles.astro';
import Contact from '../components/Contact.astro';
import CommandDeck from '../components/CommandDeck.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Andrew Acevedo Mirena // Systems Programmer"
  description="Systems programmer in Boston building public proof-of-work across distributed systems, AI infrastructure, security research, and decision-support tools."
>
  <div class="site-shell" id="top">
    <TopBar />
    <main id="main-content">
      <Hero />
      <Projects />
      <Capabilities />
      <Principles />
      <Contact />
    </main>
    <Footer />
  </div>
  <CommandDeck />
</BaseLayout>
